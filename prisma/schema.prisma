  currentCreditExposure     Decimal                 @default(0) @db.Decimal(18, 2)
  activeBusinessAccounts    Int                     @default(0)
  activeBusinessLoans       Int                     @default(0)
  activeBusinessCards       Int                     @default(0)
  paidOffBusinessLoans      Int                     @default(0)
  lastCalculatedAt          DateTime                @default(now())
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  company         Company                              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  snapshots       CompanyRelationshipProfileSnapshot[]
  recommendations CompanyRelationshipRecommendation[]
  timelineEvents  CompanyRelationshipTimelineEvent[]

  @@index([relationshipTier])
  @@index([relationshipScore])
  @@index([commercialBankingEligible])
  @@index([totalBusinessAssets])
  @@index([lastCalculatedAt])
}

model CompanyRelationshipProfileSnapshot {
  id                        String                  @id @default(cuid())
  companyId                 String
  profileId                 String
  relationshipScore         Int
  relationshipTier          CompanyRelationshipTier
  totalBusinessAssets       Decimal                 @db.Decimal(18, 2)
  currentCreditExposure     Decimal                 @db.Decimal(18, 2)
  commercialBankingEligible Boolean
  calculatedAt              DateTime                @default(now())
  metadata                  Json?

  company Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  profile CompanyRelationshipProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([companyId, calculatedAt])
  @@index([profileId])
  @@index([relationshipTier])
}

model CompanyRelationshipRecommendation {
  id                 String                              @id @default(cuid())
  companyId          String
  profileId          String
  recommendationType CompanyRelationshipRecommendationType
  status             RelationshipRecommendationStatus  @default(ACTIVE)
  title              String
  summary            String
  recommendedProduct String?
  recommendedTier    String?
  recommendedLimit   Decimal?                            @db.Decimal(18, 2)
  recommendedRate    Decimal?                            @db.Decimal(10, 6)
  confidenceScore    Int
  reasons            Json
  createdAt          DateTime                            @default(now())
  updatedAt          DateTime                            @updatedAt
  dismissedAt        DateTime?
  acceptedAt         DateTime?
  reviewedByUserId   String?

  company    Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  profile    CompanyRelationshipProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reviewedBy User?                     @relation("CompanyRelationshipRecommendationReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([profileId])
  @@index([recommendationType])
  @@index([createdAt])
}

model CompanyRelationshipTimelineEvent {
  id                String                               @id @default(cuid())
  companyId         String
  profileId         String?
  eventType         CompanyRelationshipTimelineEventType
  title             String
  description       String?
  occurredAt        DateTime
  relatedEntityType String?
  relatedEntityId   String?
  metadata          Json?
  createdAt         DateTime                             @default(now())

  company Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  profile CompanyRelationshipProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([companyId, occurredAt])
  @@index([profileId])
  @@index([eventType])
  @@index([relatedEntityType, relatedEntityId])
}
