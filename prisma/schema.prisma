generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserTag {
  ADMIN
  OPERATOR
  PRIVATE_CLIENT
  DEVELOPER
  ISSUER
}

enum AccountStatus {
  ACTIVE
  RESTRICTED
  FROZEN
  PENDING_REVIEW
}

enum DeveloperAccessStatus {
  NONE
  PENDING
  APPROVED
  SUSPENDED
}

enum CompanyType {
  PRIVATE_COMPANY
  LISTED_COMPANY
  BANK
  BROKERAGE
  ISSUER
  INSTITUTION
}

enum CompanyStatus {
  PENDING
  ACTIVE
  LISTED
  SUSPENDED
  REJECTED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum CompanyRole {
  OWNER
  EXECUTIVE
  FINANCE_MANAGER
  COMPLIANCE_CONTACT
  VIEWER
}

model User {
  id                    String                @id @default(cuid())
  discordId             String                @unique
  discordUsername       String
  discordAvatar         String?
  email                 String?
  minecraftUsername     String?
  accountStatus         AccountStatus         @default(ACTIVE)
  developerAccessStatus DeveloperAccessStatus @default(NONE)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  lastLoginAt           DateTime              @default(now())

  tags               UserTagAssignment[]
  companyMemberships CompanyMembership[]
  sessions           Session[]
  bankAccounts       BankAccount[]
  transferContacts   TransferContact[]
  reviewedBankTransactions BankTransaction[] @relation("BankTransactionReviewer")
  sentCompanyInvitations     CompanyInvitation[] @relation("SentCompanyInvitations")
  receivedCompanyInvitations CompanyInvitation[] @relation("ReceivedCompanyInvitations")
}

model UserTagAssignment {
  userId    String
  tag       UserTag
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, tag])
  @@index([tag])
}

model Company {
  id                            String             @id @default(cuid())
  name                          String
  type                          CompanyType
  ticker                        String?
  desiredTicker                 String?
  sector                        String?
  description                   String?
  headquarters                  String?
  primaryContactDiscordUsername String?
  intendedUses                  String[]           @default([])
  status                        CompanyStatus      @default(PENDING)
  verificationStatus            VerificationStatus @default(UNVERIFIED)
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime           @updatedAt

  memberships CompanyMembership[]
  bankAccounts BankAccount[]
  invitations CompanyInvitation[]
}

model CompanyMembership {
  id        String      @id @default(cuid())
  userId    String
  companyId String
  role      CompanyRole
  createdAt DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
}

enum CompanyInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

model CompanyInvitation {
  id                     String                  @id @default(cuid())
  companyId              String
  invitedByUserId        String
  invitedUserId          String?
  invitedDiscordId       String?
  invitedDiscordUsername String?
  role                   CompanyRole
  status                 CompanyInvitationStatus @default(PENDING)
  expiresAt              DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  respondedAt            DateTime?

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy   User    @relation("SentCompanyInvitations", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  invitedUser User?   @relation("ReceivedCompanyInvitations", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([invitedUserId, status])
  @@index([invitedDiscordId, status])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum BankAccountType {
  ALTA_ACCESS
  CHECKING
  SAVINGS
  RESERVE
  BUSINESS_OPERATING
  PRIVATE
}

enum BankAccountStatus {
  PENDING
  ACTIVE
  FROZEN
  CLOSED
}

enum BankTransactionType {
  DEPOSIT
  WITHDRAWAL
  ADJUSTMENT
}

enum BankTransactionStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum TransferContactScope {
  INTRABANK
  INTERBANK
}

enum IntrabankContactKind {
  OWN_ACCOUNT
  PLAYER_ACCOUNT
}

model TransferContact {
  id        String               @id @default(cuid())
  userId    String
  scope     TransferContactScope
  label     String

  intrabankKind IntrabankContactKind?
  bankAccountId String?
  accountNumber String?
  resolvedName  String?

  recipientInstitution String?
  recipientName        String?
  routingNumber        String?
  wireAccountNumber    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)

  @@index([userId, scope])
}

model BankAccount {
  id            String            @id @default(cuid())
  userId        String
  companyId     String?
  accountType   BankAccountType
  accountName   String
  accountNumber String            @unique
  status        BankAccountStatus @default(PENDING)
  balance       Decimal           @default(0) @db.Decimal(18, 2)
  currency      String            @default("FLR")
  openingNotes  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  transactions BankTransaction[]
  transferContacts TransferContact[]

  @@index([userId])
  @@index([companyId])
  @@index([status])
}

model BankTransaction {
  id            String                @id @default(cuid())
  bankAccountId String
  type          BankTransactionType
  amount        Decimal               @db.Decimal(18, 2)
  status        BankTransactionStatus @default(PENDING)
  description   String
  memo          String?
  referenceCode String                @unique
  proofImageUrl String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNote    String?

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  reviewedBy  User?       @relation("BankTransactionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([bankAccountId])
  @@index([status])
  @@index([type])
}
