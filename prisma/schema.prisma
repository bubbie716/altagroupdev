generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserTag {
  ADMIN
  OPERATOR
  PRIVATE_CLIENT
  DEVELOPER
  ISSUER
  SYSTEM
}

enum AccountStatus {
  ACTIVE
  RESTRICTED
  FROZEN
  PENDING_REVIEW
}

enum DeveloperAccessStatus {
  NONE
  PENDING
  APPROVED
  SUSPENDED
}

enum CompanyType {
  PRIVATE_COMPANY
  LISTED_COMPANY
  BANK
  BROKERAGE
  ISSUER
  INSTITUTION
}

enum CompanyStatus {
  PENDING
  ACTIVE
  LISTED
  SUSPENDED
  REJECTED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum CompanyRole {
  OWNER
  EXECUTIVE
  FINANCE_MANAGER
  COMPLIANCE_CONTACT
  VIEWER
}

model User {
  id                    String                @id @default(cuid())
  discordId             String                @unique
  discordUsername       String
  discordAvatar         String?
  email                 String?
  minecraftUsername     String?
  accountStatus         AccountStatus         @default(ACTIVE)
  developerAccessStatus DeveloperAccessStatus @default(NONE)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  lastLoginAt           DateTime              @default(now())

  tags               UserTagAssignment[]
  companyMemberships CompanyMembership[]
  sessions           Session[]
  bankAccounts               BankAccount[]
  transferContacts           TransferContact[]
  reviewedBankTransactions   BankTransaction[]   @relation("BankTransactionReviewer")
  sentCompanyInvitations     CompanyInvitation[] @relation("SentCompanyInvitations")
  receivedCompanyInvitations CompanyInvitation[] @relation("ReceivedCompanyInvitations")
  scheduledPaymentsCreated   ScheduledPayment[]  @relation("ScheduledPaymentCreator")
  payrollRunsCreated         PayrollRun[]        @relation("PayrollRunCreator")
  loanApplicationsSubmitted  LoanApplication[]   @relation("LoanApplicationApplicant")
  loanApplicationsReviewed LoanApplication[]   @relation("LoanApplicationReviewer")
  loansBorrowed              Loan[]              @relation("LoanBorrower")
  loansApproved              Loan[]              @relation("LoanApprover")
  loanLedgerEntriesCreated   LoanLedgerEntry[]   @relation("LoanLedgerCreator")
  auditLogsActed             AuditLog[]          @relation("AuditActor")
  internalNotesAuthored      InternalNote[]      @relation("InternalNoteAuthor")
  bankInterestAccrualsProcessed BankInterestAccrual[] @relation("InterestAccrualProcessor")
  scheduledManualInterestCreated ScheduledManualInterestApplication[] @relation("ScheduledManualInterestCreator")
  bankAccountHoldsCreated    BankAccountHold[]   @relation("BankAccountHoldCreator")
  bankAccountHoldsReleased   BankAccountHold[]   @relation("BankAccountHoldReleaser")
  platformSettingsUpdated    PlatformSetting[]   @relation("PlatformSettingUpdatedBy")
  dealRoomsBorrowed          DealRoom[]          @relation("DealRoomBorrower")
  dealRoomsAssigned          DealRoom[]          @relation("DealRoomOfficer")
  dealRoomParticipants       DealRoomParticipant[]
  dealRoomMessagesSent       DealRoomMessage[]   @relation("DealRoomMessageSender")
  dealRoomOffersCreated      DealRoomOffer[]     @relation("DealRoomOfferCreator")
  dealRoomDocumentsUploaded  DealRoomDocument[]  @relation("DealRoomDocumentUploader")
  dealRoomDocumentRequestsCreated DealRoomDocumentRequest[] @relation("DealRoomDocumentRequestRequestedBy")
  dealRoomDocumentRequestsReviewed DealRoomDocumentRequest[] @relation("DealRoomDocumentRequestReviewedBy")
  dealRoomAgreementDraftsGenerated DealRoomAgreementDraft[] @relation("DealRoomAgreementDraftGenerator")
  dealRoomAgreementDraftsVoided  DealRoomAgreementDraft[] @relation("DealRoomAgreementDraftVoider")
  dealRoomAgreementSignatures    DealRoomAgreementSignature[]
  dealRoomsCreated               DealRoom[]                 @relation("DealRoomCreator")
  dealRoomTasksAssigned          DealRoomTask[]             @relation("DealRoomTaskAssignee")
  dealRoomTasksCreated           DealRoomTask[]             @relation("DealRoomTaskCreator")
  dealRoomTasksCompleted         DealRoomTask[]             @relation("DealRoomTaskCompleter")
  dealRoomStageChanges           DealRoomStageHistory[]     @relation("DealRoomStageChanger")
  dealRoomStageOwnership         DealRoomStageHistory[]     @relation("DealRoomStageOwner")
  loanApplicationThreads         LoanApplicationThread[]    @relation("LoanApplicationThreadApplicant")
  loanApplicationThreadsAssigned LoanApplicationThread[]    @relation("LoanApplicationThreadStaff")
  loanApplicationThreadMessages  LoanApplicationThreadMessage[] @relation("LoanApplicationThreadMessageSender")
  userNotifications              UserNotification[]
  altaCardsOwned                 AltaCard[]                     @relation("AltaCardOwner")
  altaCardApplications           AltaCardApplication[]          @relation("AltaCardApplicant")
  altaCardApplicationsReviewed   AltaCardApplication[]          @relation("AltaCardApplicationReviewer")
  altaCardApplicationThreads         AltaCardApplicationThread[]    @relation("AltaCardApplicationThreadApplicant")
  altaCardApplicationThreadsAssigned AltaCardApplicationThread[]    @relation("AltaCardApplicationThreadStaff")
  altaCardApplicationThreadMessages  AltaCardApplicationThreadMessage[] @relation("AltaCardApplicationThreadMessageSender")
  altaCardReviewRequestsSubmitted    AltaCardReviewRequest[]          @relation("AltaCardReviewRequestApplicant")
  altaCardReviewRequestsReviewed     AltaCardReviewRequest[]          @relation("AltaCardReviewRequestReviewer")
  altaCardReviewThreads              AltaCardReviewThread[]           @relation("AltaCardReviewThreadApplicant")
  altaCardReviewThreadsAssigned      AltaCardReviewThread[]           @relation("AltaCardReviewThreadStaff")
  altaCardReviewThreadMessages       AltaCardReviewThreadMessage[]    @relation("AltaCardReviewThreadMessageSender")
  altaEmployeeCards              AltaEmployeeCard[]             @relation("AltaEmployeeCardUser")
  altaCardTransactionsCreated    AltaCardTransaction[]          @relation("AltaCardTransactionCreator")
  altaCardFeesWaived             AltaCardFee[]                  @relation("AltaCardFeeWaivedBy")
  relationshipProfile            RelationshipProfile?
  relationshipProfileSnapshots   RelationshipProfileSnapshot[]
  relationshipRecommendations    RelationshipRecommendation[]
  relationshipRecommendationsReviewed RelationshipRecommendation[] @relation("RelationshipRecommendationReviewer")
  relationshipTimelineEvents     RelationshipTimelineEvent[]
  companyRelationshipRecommendationsReviewed CompanyRelationshipRecommendation[] @relation("CompanyRelationshipRecommendationReviewer")
  opsReviewFlagsCreated          OpsReviewFlag[] @relation("OpsReviewFlagCreatedBy")
  opsReviewFlagsResolved         OpsReviewFlag[] @relation("OpsReviewFlagResolvedBy")
  opsExceptionDispositionsActed  OpsExceptionDisposition[] @relation("OpsExceptionDispositionActor")
  altaPrivateInvitationsReceived AltaPrivateInvitation[] @relation("AltaPrivateInvitationRecipient")
  altaPrivateInvitationsSent     AltaPrivateInvitation[] @relation("AltaPrivateInvitationSender")
}

model UserTagAssignment {
  userId    String
  tag       UserTag
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, tag])
  @@index([tag])
}

model Company {
  id                            String             @id @default(cuid())
  name                          String
  type                          CompanyType
  ticker                        String?
  desiredTicker                 String?
  sector                        String?
  description                   String?
  headquarters                  String?
  primaryContactDiscordUsername String?
  intendedUses                  String[]           @default([])
  status                        CompanyStatus      @default(PENDING)
  verificationStatus            VerificationStatus @default(UNVERIFIED)
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime           @updatedAt

  memberships       CompanyMembership[]
  bankAccounts      BankAccount[]
  invitations       CompanyInvitation[]
  scheduledPayments ScheduledPayment[]
  payrollEmployees  PayrollEmployee[]
  payrollRuns       PayrollRun[]
  loanApplications  LoanApplication[]
  loans             Loan[]
  dealRooms         DealRoom[]
  loanApplicationThreads LoanApplicationThread[]
  altaCards            AltaCard[]
  altaCardApplications AltaCardApplication[]
  altaCardApplicationThreads AltaCardApplicationThread[]
  altaCardReviewRequests     AltaCardReviewRequest[]
  altaCardReviewThreads      AltaCardReviewThread[]
  altaEmployeeCards    AltaEmployeeCard[]
  altaCardMerchantTransactions AltaCardTransaction[] @relation("AltaCardMerchantCompany")
  relationshipProfile          CompanyRelationshipProfile?
  relationshipSnapshots        CompanyRelationshipProfileSnapshot[]
  relationshipRecommendations  CompanyRelationshipRecommendation[]
  relationshipTimelineEvents   CompanyRelationshipTimelineEvent[]
}

model CompanyMembership {
  id        String      @id @default(cuid())
  userId    String
  companyId String
  role      CompanyRole
  createdAt DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
}

enum CompanyInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

model CompanyInvitation {
  id                     String                  @id @default(cuid())
  companyId              String
  invitedByUserId        String
  invitedUserId          String?
  invitedDiscordId       String?
  invitedDiscordUsername String?
  role                   CompanyRole
  status                 CompanyInvitationStatus @default(PENDING)
  expiresAt              DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  respondedAt            DateTime?

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy   User    @relation("SentCompanyInvitations", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  invitedUser User?   @relation("ReceivedCompanyInvitations", fields: [invitedUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([invitedUserId, status])
  @@index([invitedDiscordId, status])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum BankAccountType {
  ALTA_ACCESS
  CHECKING
  SAVINGS
  MONEY_MARKET
  RESERVE
  BUSINESS_OPERATING
  PRIVATE
}

enum BankAccountStatus {
  PENDING
  ACTIVE
  FROZEN
  CLOSED
}

enum BankTransactionType {
  DEPOSIT
  WITHDRAWAL
  ADJUSTMENT
  LOAN_PAYMENT
  INTEREST_CHARGE
  INTEREST_CREDIT
}

enum InterestRatePeriod {
  MONTHLY
}

enum BankInterestAccrualStatus {
  PENDING
  PROCESSED
  SKIPPED
  FAILED
}

enum ScheduledManualInterestStatus {
  PENDING
  APPLIED
  CANCELLED
  FAILED
}

enum BankTransactionStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

enum TransferContactScope {
  INTRABANK
  INTERBANK
}

enum IntrabankContactKind {
  OWN_ACCOUNT
  PLAYER_ACCOUNT
}

model TransferContact {
  id        String               @id @default(cuid())
  userId    String
  scope     TransferContactScope
  label     String

  intrabankKind IntrabankContactKind?
  bankAccountId String?
  accountNumber String?
  resolvedName  String?

  recipientInstitution String?
  recipientName        String?
  routingNumber        String?
  wireAccountNumber    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)

  @@index([userId, scope])
}

model BankAccount {
  id            String            @id @default(cuid())
  userId        String
  companyId     String?
  accountType   BankAccountType
  accountName   String
  accountNumber String            @unique
  status        BankAccountStatus @default(PENDING)
  balance       Decimal           @default(0) @db.Decimal(18, 2)
  currency      String            @default("FLR")
  openingNotes  String?
  interestRate           Decimal            @default(0) @db.Decimal(10, 6)
  interestRatePeriod     InterestRatePeriod?
  interestAccrualEnabled Boolean            @default(false)
  lastInterestAccruedAt  DateTime?
  nextInterestAccrualAt  DateTime?
  restrictDeposits     Boolean           @default(false)
  restrictWithdrawals  Boolean           @default(false)
  restrictTransfers    Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      Company?          @relation(fields: [companyId], references: [id], onDelete: SetNull)
  holds        BankAccountHold[]
  transactions      BankTransaction[]
  interestAccruals  BankInterestAccrual[]
  transferContacts  TransferContact[]
  scheduledPayments ScheduledPayment[]
  payrollRuns       PayrollRun[]
  statements        BankStatement[]
  loanApplications  LoanApplication[]
  loansLinked       Loan[]            @relation("LoanLinkedAccount")
  loansAutoPaySource Loan[]           @relation("LoanAutoPaySource")
  altaCardAutopaySource AltaCard[]    @relation("AltaCardAutopaySource")
  loanPaymentsFrom  LoanPayment[]
  altaCardTransactions AltaCardTransaction[] @relation("AltaCardRelatedBankAccount")
  altaCardApplicationsPaymentSource AltaCardApplication[] @relation("AltaCardApplicationPaymentSource")

  @@index([userId])
  @@index([companyId])
  @@index([status])
}

enum ScheduledTransferScope {
  INTRABANK
  INTERBANK
}

enum ScheduledPaymentType {
  ONE_TIME
  SCHEDULED
  RECURRING
}

enum PaymentFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
}

enum ScheduledPaymentStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXECUTED
  CANCELLED
  PAUSED
  FAILED
}

enum ScheduledTransferExecutionStatus {
  PENDING
  EXECUTED
  FAILED
  SKIPPED
}

enum PayrollEmployeeStatus {
  ACTIVE
  INACTIVE
}

enum PayrollRunStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXECUTED
  CANCELLED
  FAILED
}

model ScheduledPayment {
  id                     String                 @id @default(cuid())
  companyId              String?
  bankAccountId          String
  createdByUserId        String
  transferScope          ScheduledTransferScope @default(INTRABANK)
  paymentType            ScheduledPaymentType
  label                  String
  recipientName          String
  recipientAccountNumber String?
  recipientInstitution   String?
  routingNumber          String?
  wireAccountNumber      String?
  amount                 Decimal                @db.Decimal(18, 2)
  currency               String                 @default("FLR")
  frequency              PaymentFrequency?
  scheduledDate          DateTime?
  nextRunDate            DateTime?
  lastRunAt              DateTime?
  consecutiveFailures    Int                    @default(0)
  lastFailureReason      String?
  lastExecutionStatus    ScheduledTransferExecutionStatus?
  status                 ScheduledPaymentStatus @default(PENDING_REVIEW)
  memo                   String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  company     Company?    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("ScheduledPaymentCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  executions  ScheduledTransferExecution[]

  @@index([companyId])
  @@index([createdByUserId])
  @@index([transferScope])
  @@index([bankAccountId])
  @@index([status])
  @@index([paymentType])
  @@index([nextRunDate])
  @@index([scheduledDate])
}

model ScheduledTransferExecution {
  id                 String                           @id @default(cuid())
  scheduledPaymentId String
  scheduledRunAt     DateTime
  status             ScheduledTransferExecutionStatus @default(PENDING)
  bankTransactionId  String?
  failureReason      String?
  executedAt         DateTime?
  createdAt          DateTime                         @default(now())

  scheduledPayment ScheduledPayment @relation(fields: [scheduledPaymentId], references: [id], onDelete: Cascade)
  bankTransaction  BankTransaction? @relation(fields: [bankTransactionId], references: [id], onDelete: SetNull)

  @@unique([scheduledPaymentId, scheduledRunAt])
  @@index([scheduledPaymentId])
  @@index([status])
  @@index([scheduledRunAt])
}

model PayrollEmployee {
  id            String                @id @default(cuid())
  companyId     String
  displayName   String
  title         String?
  accountNumber String
  payAmount     Decimal               @db.Decimal(18, 2)
  payFrequency  PaymentFrequency      @default(MONTHLY)
  payDay        String
  nextPayDate   DateTime?
  lastPaidAt    DateTime?
  status        PayrollEmployeeStatus @default(ACTIVE)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  autoPayrollRuns PayrollRun[] @relation("AutoPayrollEmployee")

  @@index([companyId])
  @@index([status])
  @@index([nextPayDate])
}

model PayrollRun {
  id                  String           @id @default(cuid())
  companyId           String
  bankAccountId       String
  createdByUserId     String
  label               String
  totalAmount         Decimal          @db.Decimal(18, 2)
  status              PayrollRunStatus @default(PENDING_REVIEW)
  payDate             DateTime
  lineItems           Json
  memo                String?
  consecutiveFailures Int              @default(0)
  lastFailureReason   String?
  lastRunAt           DateTime?
  autoEmployeeId      String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankAccount   BankAccount      @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  createdBy     User             @relation("PayrollRunCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  autoEmployee  PayrollEmployee? @relation("AutoPayrollEmployee", fields: [autoEmployeeId], references: [id], onDelete: SetNull)
  executions    PayrollRunExecution[]

  @@index([companyId])
  @@index([bankAccountId])
  @@index([status])
  @@index([payDate])
  @@index([autoEmployeeId])
}

model PayrollRunExecution {
  id             String                           @id @default(cuid())
  payrollRunId   String
  scheduledRunAt DateTime
  status         ScheduledTransferExecutionStatus @default(PENDING)
  failureReason  String?
  executedAt     DateTime?
  createdAt      DateTime                         @default(now())

  payrollRun     PayrollRun                @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  lineExecutions PayrollRunLineExecution[]

  @@unique([payrollRunId, scheduledRunAt])
  @@index([payrollRunId])
  @@index([status])
  @@index([scheduledRunAt])
}

model PayrollRunLineExecution {
  id                    String                           @id @default(cuid())
  payrollRunExecutionId String
  employeeId            String
  displayName           String
  accountNumber         String
  amount                Decimal                          @db.Decimal(18, 2)
  status                ScheduledTransferExecutionStatus @default(PENDING)
  bankTransactionId     String?
  failureReason         String?
  executedAt            DateTime?
  createdAt             DateTime                         @default(now())

  payrollRunExecution PayrollRunExecution @relation(fields: [payrollRunExecutionId], references: [id], onDelete: Cascade)
  bankTransaction     BankTransaction?    @relation(fields: [bankTransactionId], references: [id], onDelete: SetNull)

  @@unique([payrollRunExecutionId, employeeId])
  @@index([payrollRunExecutionId])
  @@index([status])
}

model BankTransaction {
  id            String                @id @default(cuid())
  bankAccountId String
  type          BankTransactionType
  amount        Decimal               @db.Decimal(18, 2)
  status        BankTransactionStatus @default(PENDING)
  description   String
  memo          String?
  referenceCode String                @unique
  proofImageUrl String?
  proofFileName String?
  proofUploadedAt DateTime?
  proofMimeType String?
  proofSizeBytes Int?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNote    String?

  bankAccount                BankAccount                  @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  reviewedBy                 User?                        @relation("BankTransactionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  scheduledTransferExecution ScheduledTransferExecution[]
  payrollRunLineExecution    PayrollRunLineExecution[]
  loanPayment                LoanPayment?
  loanLedgerEntries          LoanLedgerEntry[]
  interestAccrual            BankInterestAccrual?
  altaCardTransactions       AltaCardTransaction[] @relation("AltaCardRelatedBankTransaction")

  @@index([bankAccountId])
  @@index([status])
  @@index([type])
}

model BankInterestAccrual {
  id                String                    @id @default(cuid())
  bankAccountId     String
  periodStart       DateTime
  periodEnd         DateTime
  interestRate      Decimal                   @db.Decimal(10, 6)
  openingBalance    Decimal                   @db.Decimal(18, 2)
  interestAmount    Decimal                   @default(0) @db.Decimal(18, 2)
  status            BankInterestAccrualStatus @default(PENDING)
  bankTransactionId String?                   @unique
  createdAt         DateTime                  @default(now())
  processedAt       DateTime?
  processedById     String?
  failureReason     String?

  bankAccount     BankAccount      @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  bankTransaction BankTransaction? @relation(fields: [bankTransactionId], references: [id], onDelete: SetNull)
  processedBy     User?            @relation("InterestAccrualProcessor", fields: [processedById], references: [id], onDelete: SetNull)

  @@unique([bankAccountId, periodStart, periodEnd])
  @@index([bankAccountId])
  @@index([status])
}

model ScheduledManualInterestApplication {
  id               String                        @id @default(cuid())
  createdByUserId  String
  payload          Json
  scheduledFor     DateTime
  idempotencyKey   String                        @unique
  status           ScheduledManualInterestStatus @default(PENDING)
  batchReferenceId String?
  appliedAt        DateTime?
  failureReason    String?
  applyResult      Json?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt

  createdBy User @relation("ScheduledManualInterestCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([status, scheduledFor])
  @@index([createdByUserId])
}

enum BankStatementStatus {
  DRAFT
  GENERATED
  VOID
}

model BankStatement {
  id                String              @id @default(cuid())
  bankAccountId     String
  statementNumber   String              @unique
  periodStart       DateTime
  periodEnd         DateTime
  openingBalance    Decimal             @db.Decimal(18, 2)
  closingBalance    Decimal             @db.Decimal(18, 2)
  totalDeposits     Decimal             @db.Decimal(18, 2)
  totalWithdrawals  Decimal             @db.Decimal(18, 2)
  totalTransfersIn  Decimal             @db.Decimal(18, 2)
  totalTransfersOut Decimal             @db.Decimal(18, 2)
  transactionCount  Int
  status            BankStatementStatus @default(GENERATED)
  generatedAt       DateTime?
  createdAt         DateTime            @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@index([bankAccountId])
  @@index([status])
  @@index([periodStart, periodEnd])
}

enum LoanProductType {
  PERSONAL_CREDIT_LINE
  BUSINESS_CREDIT_LINE
  PRIVATE_LIQUIDITY_LINE
}

enum LoanApplicationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  DENIED
  CANCELLED
}

enum LoanStatus {
  ACTIVE
  PAID_OFF
  DEFAULTED
  CANCELLED
  FROZEN
}

enum LoanInterestRateType {
  ANNUAL_PERCENT
  MONTHLY_PERCENT
}

enum LoanLedgerEntryType {
  DISBURSEMENT
  PAYMENT
  INTEREST_CHARGE
  ADJUSTMENT
  STATUS_CHANGE
}

enum LoanPaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum LoanScheduleInstallmentStatus {
  PENDING
  PAID
  OVERDUE
  FAILED
}

model LoanApplication {
  id                    String                @id @default(cuid())
  applicantUserId       String
  companyId             String?
  productType           LoanProductType
  requestedAmount       Decimal               @db.Decimal(18, 2)
  termMonths            Int
  purpose               String
  repaymentPlan         String
  collateralDescription String?
  notes                 String?
  linkedBankAccountId   String?
  status                LoanApplicationStatus @default(PENDING)
  reviewNote            String?
  reviewedById          String?
  reviewedAt            DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  applicantUser     User         @relation("LoanApplicationApplicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  company           Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  linkedBankAccount BankAccount? @relation(fields: [linkedBankAccountId], references: [id], onDelete: SetNull)
  reviewedBy        User?        @relation("LoanApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  loan              Loan?
  dealRoom          DealRoom?
  thread            LoanApplicationThread?

  @@index([applicantUserId])
  @@index([companyId])
  @@index([status])
  @@index([productType])
  @@index([createdAt])
}

enum LoanApplicationThreadStatus {
  OPEN
  WAITING_ON_APPLICANT
  WAITING_ON_ALTA
  CLOSED
}

enum LoanApplicationThreadSenderRole {
  APPLICANT
  ALTA_STAFF
  SYSTEM
}

model LoanApplicationThread {
  id                String                      @id @default(cuid())
  loanApplicationId String                      @unique
  applicantUserId   String
  companyId         String?
  status            LoanApplicationThreadStatus @default(OPEN)
  /// Deprecated: unused in V1 (no staff assignment). Retained for schema compatibility.
  assignedStaffId   String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  closedAt          DateTime?

  loanApplication LoanApplication                @relation(fields: [loanApplicationId], references: [id], onDelete: Cascade)
  applicantUser   User                           @relation("LoanApplicationThreadApplicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  company         Company?                       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignedStaff   User?                          @relation("LoanApplicationThreadStaff", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  messages        LoanApplicationThreadMessage[]

