{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "ncc.altagroup.dev" }],
      "destination": "https://newportclearingcorporation.com/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.newportclearingcorporation.com" }],
      "destination": "https://newportclearingcorporation.com/:path*",
      "permanent": true
    }
  ]
}
