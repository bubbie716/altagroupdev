# PostgreSQL (required for auth persistence)
# Neon: use the *pooler* host (…-pooler.…neon.tech) and sslmode=require — avoid channel_binding=require with Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/alta_dev?schema=public

# Discord OAuth (server-only — never expose client secret to the browser)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
# Dev: comma-separate LAN callback(s) too, and register each in Discord OAuth2 redirects.
# Example: http://localhost:3000/api/auth/discord/callback,http://192.168.1.10:3000/api/auth/discord/callback
# In development the app auto-matches the host you browse from (localhost or LAN).

# Session cookie + OAuth state signing (min 32 characters — generate with: openssl rand -base64 32)
SESSION_SECRET=

# Discord bot (server-only — for internal embed sending via /internal/embeds)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_INFORMATION=
DISCORD_CHANNEL_ANNOUNCEMENTS=
DISCORD_CHANNEL_BANK_NOTICES=
DISCORD_CHANNEL_EXCHANGE_NOTICES=
DISCORD_CHANNEL_TERMINAL_UPDATES=
DISCORD_CHANNEL_DEVELOPER_UPDATES=
DISCORD_CHANNEL_INTERNAL_LOG=

# Cron job authentication (server-only — scheduled transfer auto-execution)
CRON_SECRET=

# Vercel Blob (server-only — deposit/withdrawal proof screenshots)
BLOB_READ_WRITE_TOKEN=
# Match your Blob store type: "public" (default) or "private"
BLOB_ACCESS=public

# UI LAB ONLY — DO NOT ENABLE IN PRODUCTION
# Bypass auth & inject mock user for design preview (see docs/ui-lab-mode.md)
VITE_UI_LAB_MODE=false
