{
  "name": "altaweb",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "vercel-build": "vite build",
    "build:local": "prisma generate && vite build",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:grant-tag": "tsx prisma/grant-tag.ts",
    "db:backfill-loan-interest": "tsx prisma/backfill-loan-interest.ts",
    "db:backfill-loan-balance-split": "tsx prisma/backfill-loan-balance-split.ts",
    "db:backfill-loan-interest-guarantee": "tsx prisma/backfill-loan-interest-guarantee.ts",
    "db:backfill-cancelled-review-messages": "tsx prisma/backfill-cancelled-review-messages.ts",
    "db:backfill-alta-card-application-approval-messages": "tsx prisma/backfill-alta-card-application-approval-messages.ts",
    "db:backfill-relationship-timelines": "tsx prisma/backfill-relationship-timelines.ts",
    "db:backfill-company-relationship-timelines": "tsx prisma/backfill-company-relationship-timelines.ts",
    "db:backfill-transaction-descriptions": "tsx prisma/backfill-transaction-descriptions.ts",
    "db:activate-pending-private-accounts": "tsx prisma/activate-pending-private-accounts.ts",
    "db:liquidate-revoked-private-banking": "tsx prisma/liquidate-revoked-private-banking.ts",
    "db:migrate-account-numbers": "tsx prisma/migrate-legacy-account-numbers.ts",
    "postinstall": "prisma generate",
    "test:e2e": "npm run test:e2e:auth && playwright test",
    "test:e2e:headed": "npm run test:e2e:auth && playwright test --headed",
    "test:e2e:ui": "npm run test:e2e:auth && playwright test --ui --ui-host=127.0.0.1 --ui-port=9323",
    "test:e2e:ui:only": "playwright test --ui --ui-host=127.0.0.1 --ui-port=9323",
    "test:e2e:report": "playwright show-report",
    "test:e2e:seed": "tsx tests/e2e/scripts/seed-e2e-data.ts",
    "test:e2e:auth": "tsx tests/e2e/scripts/run-global-setup.ts",
    "test:unit": "find src -name '*.test.ts' ! -name '*.integration.test.ts' ! -name 'footer-links.test.ts' ! -name 'site-scoped-content.test.ts' ! -name 'audit-log-discord-bridge.test.ts' ! -name 'customer-operator-notification.test.ts' -print0 | xargs -0 npx tsx --test",
    "test:unit:integration": "find src -name '*.integration.test.ts' -print0 | xargs -0 npx tsx --test"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-start": "^1.167.50",
    "@tanstack/router-plugin": "^1.167.28",
    "@vercel/blob": "^2.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "html2canvas-pro": "^2.1.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.575.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "prisma": "^6.19.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.3.4",
    "vite-tsconfig-paths": "^6.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@lovable.dev/vite-tanstack-config": "2.6.2",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "nitro": "3.0.260603-beta",
    "prettier": "^3.7.3",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.16"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
